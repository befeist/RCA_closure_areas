coords <- do.call(rbind, lapply(endpoints_line, st_coordinates))
# Create a LINESTRING from the coordinates
line_from_endpoints <- st_linestring(coords)
# To create an sf object from the LINESTRING
line_feature1 <- st_sf(geometry = st_sfc(line_from_endpoints, crs = st_crs(endpoints_line1)))
