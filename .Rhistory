# Initialize a list to store the results or errors
results <- list()
# Initialize a list to store success or failure indicators
status_list <- list()
for (i in 1:nrow(intructions_sample)) {
# For each row in intructions_sample, extract the boundary names
lat_boundary1_name <- intructions_sample$lat_boundary1[i]
lat_boundary2_name <- intructions_sample$lat_boundary2[i]
lon_boundary1_name <- intructions_sample$lon_boundary1[i]
lon_boundary2_name <- intructions_sample$lon_boundary2[i]
# Select latitude lines
selected_latitude_lines <- suppressMessages(lat_boundary[lat_boundary$boundary_name == lat_boundary1_name, ]) %>%
rbind(suppressMessages(lat_boundary[lat_boundary$boundary_name == lat_boundary2_name, ]))
# Select longitude lines
selected_longitude_lines <- suppressMessages(lon_boundary[lon_boundary$boundary_name == lon_boundary1_name, ]) %>%
rbind(suppressMessages(lon_boundary[lon_boundary$boundary_name == lon_boundary2_name, ]))
# Try to process the selected lines to create polygons, suppressing messages
try({
result <- suppressMessages(rca_lines_to_polygons_v4(selected_longitude_lines, selected_latitude_lines, eez_poly))
# Combine polygons into multipolygons and assign the instructions df variable levels, suppressing messages
combined_sf <- suppressMessages(result %>%
st_combine() %>%
st_sf() %>%
cbind(intructions_sample[i,]))
# Store each successful result in the results list
results[[i]] <- combined_sf
# Indicate success for this iteration
status_list[[i]] <- "Success"
}, error = function(e) {
# In case of an error, store the error message instead of the result
results[[i]] <- e
# Indicate failure for this iteration
status_list[[i]] <<- "Failure"
})
}
# Initialize a list to store the results or errors
