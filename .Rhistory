# Initialize vectors to store success or failure status and possibly error messages
status_vector <- rep(NA, nrow(intructions_sample))
error_messages <- rep("", nrow(intructions_sample))
for (i in 1:nrow(intructions_sample)) {
# Extract the boundary names for each row
lat_boundary1_name <- intructions_sample$lat_boundary1[i]
lat_boundary2_name <- intructions_sample$lat_boundary2[i]
lon_boundary1_name <- intructions_sample$lon_boundary1[i]
lon_boundary2_name <- intructions_sample$lon_boundary2[i]
# Select latitude and longitude lines
selected_latitude_lines <- lat_boundary[lat_boundary$boundary_name == lat_boundary1_name, ] %>%
rbind(lat_boundary[lat_boundary$boundary_name == lat_boundary2_name, ])
selected_longitude_lines <- lon_boundary[lon_boundary$boundary_name == lon_boundary1_name, ] %>%
rbind(lon_boundary[lon_boundary$boundary_name == lon_boundary2_name, ])
# Process the lines to create polygons, handling errors
result <- tryCatch({
suppressMessages(rca_lines_to_polygons_v4(selected_longitude_lines, selected_latitude_lines, eez_poly))
}, error = function(e) {
e
})
if(inherits(result, "error")) {
status_vector[i] <- "Failure"
error_messages[i] <- result$message
} else {
status_vector[i] <- "Success"
# Optional: Store additional success details if necessary
}
}
# Combine the status and messages into a data frame
results_df <- data.frame(
Row = 1:nrow(intructions_sample),
Status = status_vector,
ErrorMessage = error_messages
)
# Print the results data frame to check
summary(results_df)
