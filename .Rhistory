lon_boundary2_name <- intructions_sample$lon_boundary2[i]
# Select latitude lines
selected_latitude_lines <- lat_boundary[lat_boundary$boundary_name == lat_boundary1_name, ] %>%
rbind(lat_boundary[lat_boundary$boundary_name == lat_boundary2_name, ])
# Select longitude lines
selected_longitude_lines <- lon_boundary[lon_boundary$boundary_name == lon_boundary1_name, ] %>%
rbind(lon_boundary[lon_boundary$boundary_name == lon_boundary2_name, ])
# Try to process the selected lines to create polygons
try({
result <- rca_lines_to_polygons_v4(selected_longitude_lines, selected_latitude_lines, eez_poly)
# Combine polygons into multipolygons and assign the instructions df variable levels
combined_sf <- result %>%
st_combine() %>%
st_sf() %>%
cbind(intructions_sample[i,])
# Store each successful result in the results list
results[[i]] <- combined_sf
# Indicate success for this iteration
status_list[[i]] <- "Success"
}, error = function(e) {
# In case of an error, store the error message instead of the result
results[[i]] <- e
# Indicate failure for this iteration
status_list[[i]] <<-"Failure"
})
}
# Initialize a list to store the results or errors
results <- list()
# Initialize a list to store success or failure indicators
status_list <- list()
for (i in 1:nrow(intructions_sample)) {
# For each row in intructions_sample, extract the boundary names
lat_boundary1_name <- intructions_sample$lat_boundary1[i]
lat_boundary2_name <- intructions_sample$lat_boundary2[i]
lon_boundary1_name <- intructions_sample$lon_boundary1[i]
lon_boundary2_name <- intructions_sample$lon_boundary2[i]
# Select latitude lines
selected_latitude_lines <- lat_boundary[lat_boundary$boundary_name == lat_boundary1_name, ] %>%
rbind(lat_boundary[lat_boundary$boundary_name == lat_boundary2_name, ])
# Select longitude lines
selected_longitude_lines <- lon_boundary[lon_boundary$boundary_name == lon_boundary1_name, ] %>%
rbind(lon_boundary[lon_boundary$boundary_name == lon_boundary2_name, ])
# Use tryCatch for error handling
result <- tryCatch({
# Suppress messages from this operation
suppressMessages(rca_lines_to_polygons_v4(selected_longitude_lines, selected_latitude_lines, eez_poly))
}, error = function(e) {
# Handle the error case
e
})
# Check if the result is an error
if(inherits(result, "error")) {
# Store the error message and indicate failure
results[[i]] <- result$message
status_list[[i]] <- "Failure"
} else {
# If no error, proceed to combine polygons and indicate success
combined_sf <- result %>%
st_combine() %>%
st_sf() %>%
cbind(intructions_sample[i,])
# Store each successful result
results[[i]] <- combined_sf
status_list[[i]] <- "Success"
}
}
# If you want to check the status list separately, it's now available
print(status_list)
