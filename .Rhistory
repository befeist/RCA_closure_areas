extract_endpoints <- function(line) {
start_point <- lwgeom::st_startpoint(line) %>% st_sf()
end_point <- lwgeom::st_endpoint(line) %>% st_sf()
# Combine the start and end points into a single sfc object
points <- rbind(start_point,end_point)
return(points)
}
