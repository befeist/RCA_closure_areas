.groups = "drop"
)
df_annual <- df_monthly_z %>%
group_by(year, Species_ID) %>%
summarise(
Avg_Z_Score = mean(Z_Score),
.groups = "drop"
)
species_performance <- df_annual %>%
group_by(Species_ID) %>%
summarise(
Mean_Z_Across_Years = mean(Avg_Z_Score),
p_value = t.test(Avg_Z_Score, mu = 0, alternative = "greater")$p.value
)
